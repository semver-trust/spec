        "active_policy": "policy-a",
        "candidate_policy": "policy-a",
        "bootstrap": "bootstrap-a",
        "predecessor": null,
        "provided_trust_material": {
          ".semver-trust/humans": "sha256:humans-a",
          ".semver-trust/attesters": "sha256:attesters-a"
